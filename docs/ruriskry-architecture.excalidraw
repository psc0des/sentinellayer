    { "type": "text", "id": "s1_mon_text", "x": 70, "y": 184, "width": 250, "height": 50, "text": "\ud83d\udd0d  Monitoring Agent\n6-step infra scan", "originalText": "\ud83d\udd0d  Monitoring Agent\n6-step infra scan", "fontSize": 14, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100015, "version": 1, "versionNonce": 100016, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s1_mon_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s1_evidence_rect", "x": 58, "y": 265, "width": 274, "height": 195, "strokeColor": "#22c55e", "backgroundColor": "#1e293b", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100017, "version": 1, "versionNonce": 100018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s1_evidence_text", "x": 68, "y": 272, "width": 254, "height": 181, "text": "// Cost Agent \u2192 ProposedAction\n{\n  action: DELETE_RESOURCE\n  resource_id: \"vm-23\"\n  reason: \"costs $847/mo,\n           idle 30 days\"\n  tags: {\n    purpose: \"disaster-recovery\"\n  }\n}", "originalText": "// Cost Agent \u2192 ProposedAction\n{\n  action: DELETE_RESOURCE\n  resource_id: \"vm-23\"\n  reason: \"costs $847/mo,\n           idle 30 days\"\n  tags: {\n    purpose: \"disaster-recovery\"\n  }\n}", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100019, "version": 1, "versionNonce": 100020, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4 },

