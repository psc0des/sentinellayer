    { "type": "text", "id": "azure_label", "x": 70, "y": 1048, "width": 300, "height": 16, "text": "AZURE SERVICES (Microsoft Foundry Platform)", "originalText": "AZURE SERVICES (Microsoft Foundry Platform)", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600003, "version": 1, "versionNonce": 600004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "azure_services", "x": 70, "y": 1070, "width": 2060, "height": 56, "text": "\ud83e\udde0  Azure OpenAI Foundry (gpt-5-mini \u2014 7 agent loops)       \ud83d\uddfa\ufe0f  Resource Graph (KQL live topology)       \ud83d\udd0e  AI Search (BM25 incident similarity)       \ud83d\uddc4\ufe0f  Cosmos DB (audit trail)\n\ud83d\udd10  Key Vault (secrets)       \ud83d\udce1  Azure Monitor (alert rules \u2192 webhook)       \ud83d\ude80  Container Apps (backend + sticky sessions)       \ud83c\udf10  Static Web Apps (React dashboard)", "originalText": "\ud83e\udde0  Azure OpenAI Foundry (gpt-5-mini \u2014 7 agent loops)       \ud83d\uddfa\ufe0f  Resource Graph (KQL live topology)       \ud83d\udd0e  AI Search (BM25 incident similarity)       \ud83d\uddc4\ufe0f  Cosmos DB (audit trail)\n\ud83d\udd10  Key Vault (secrets)       \ud83d\udce1  Azure Monitor (alert rules \u2192 webhook)       \ud83d\ude80  Container Apps (backend + sticky sessions)       \ud83c\udf10  Static Web Apps (React dashboard)", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#3b82f6", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600005, "version": 1, "versionNonce": 600006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 }
