    { "type": "text", "id": "s3_label", "x": 400, "y": 148, "width": 760, "height": 18, "text": "RURISKRY GOVERNANCE CORE", "originalText": "RURISKRY GOVERNANCE CORE", "fontSize": 11, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#6d28d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300003, "version": 1, "versionNonce": 300004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_pipeline_rect", "x": 395, "y": 168, "width": 770, "height": 65, "strokeColor": "#6d28d9", "backgroundColor": "#ddd6fe", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300005, "version": 1, "versionNonce": 300006, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_pipeline_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_pipeline_text", "x": 395, "y": 176, "width": 770, "height": 50, "text": "RuriSkryPipeline.evaluate(action)\nUnified entry \u2014 intercepts every action before it touches infrastructure", "originalText": "RuriSkryPipeline.evaluate(action)\nUnified entry \u2014 intercepts every action before it touches infrastructure", "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300007, "version": 1, "versionNonce": 300008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_pipeline_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_triage_rect", "x": 395, "y": 250, "width": 770, "height": 44, "strokeColor": "#b45309", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300009, "version": 1, "versionNonce": 300010, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_triage_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_triage_text", "x": 395, "y": 256, "width": 770, "height": 32, "text": "\u26a1 Risk Triage:  T1 \u2014 non-prod, isolated \u2192 deterministic (0 LLM)  |  T2 \u2014 prod \u2192 single LLM  |  T3 \u2014 compliance/destructive \u2192 full pipeline", "originalText": "\u26a1 Risk Triage:  T1 \u2014 non-prod, isolated \u2192 deterministic (0 LLM)  |  T2 \u2014 prod \u2192 single LLM  |  T3 \u2014 compliance/destructive \u2192 full pipeline", "fontSize": 11, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300011, "version": 1, "versionNonce": 300012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_triage_rect", "lineHeight": 1.25 },

    { "type": "text", "id": "s3_parallel_label", "x": 395, "y": 302, "width": 770, "height": 20, "text": "asyncio.gather() \u2014 all 4 governance agents score the action concurrently", "originalText": "asyncio.gather() \u2014 all 4 governance agents score the action concurrently", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#6d28d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300013, "version": 1, "versionNonce": 300014, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_blast_rect", "x": 395, "y": 328, "width": 370, "height": 120, "strokeColor": "#6d28d9", "backgroundColor": "#ddd6fe", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300015, "version": 1, "versionNonce": 300016, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_blast_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_blast_text", "x": 395, "y": 346, "width": 370, "height": 85, "text": "\ud83d\udca5 Blast Radius  (SRI:Infrastructure, w=0.30)\nHow many downstream resources\nare affected by this action?", "originalText": "\ud83d\udca5 Blast Radius  (SRI:Infrastructure, w=0.30)\nHow many downstream resources\nare affected by this action?", "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300017, "version": 1, "versionNonce": 300018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_blast_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_policy_rect", "x": 795, "y": 328, "width": 375, "height": 120, "strokeColor": "#b91c1c", "backgroundColor": "#fee2e2", "fillStyle": "solid", "strokeWidth": 3, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300019, "version": 1, "versionNonce": 300020, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_policy_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_policy_text", "x": 795, "y": 340, "width": 375, "height": 95, "text": "\ud83d\udccb Policy Compliance  (SRI:Policy, w=0.25)\nPOL-DR-001 CRITICAL fired!\n\u26a0\ufe0f Disaster-recovery VM deletion\nprohibited \u2014 override blocks action", "originalText": "\ud83d\udccb Policy Compliance  (SRI:Policy, w=0.25)\nPOL-DR-001 CRITICAL fired!\n\u26a0\ufe0f Disaster-recovery VM deletion\nprohibited \u2014 override blocks action", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300021, "version": 1, "versionNonce": 300022, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_policy_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_hist_rect", "x": 395, "y": 464, "width": 370, "height": 115, "strokeColor": "#b45309", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300023, "version": 1, "versionNonce": 300024, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_hist_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_hist_text", "x": 395, "y": 480, "width": 370, "height": 82, "text": "\ud83d\udcdc Historical Pattern  (SRI:Historical, w=0.25)\nBM25 incident search \u2014 no past\nincidents matching this action pattern", "originalText": "\ud83d\udcdc Historical Pattern  (SRI:Historical, w=0.25)\nBM25 incident search \u2014 no past\nincidents matching this action pattern", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300025, "version": 1, "versionNonce": 300026, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_hist_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_fin_rect", "x": 795, "y": 464, "width": 375, "height": 115, "strokeColor": "#047857", "backgroundColor": "#a7f3d0", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300027, "version": 1, "versionNonce": 300028, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "s3_fin_text", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_fin_text", "x": 795, "y": 480, "width": 375, "height": 82, "text": "\ud83d\udcca Financial Impact  (SRI:Cost, w=0.20)\nSaves $847/mo \u2014 but compliance\nrisk outweighs cost saving", "originalText": "\ud83d\udcca Financial Impact  (SRI:Cost, w=0.20)\nSaves $847/mo \u2014 but compliance\nrisk outweighs cost saving", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300029, "version": 1, "versionNonce": 300030, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_fin_rect", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "s3_sri_rect", "x": 395, "y": 593, "width": 775, "height": 160, "strokeColor": "#6d28d9", "backgroundColor": "#1e293b", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300031, "version": 1, "versionNonce": 300032, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "s3_sri_text", "x": 408, "y": 602, "width": 749, "height": 143, "text": "SRI\u2122 Composite Score\n\nSRI:Infrastructure   32 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591   3 downstream deps affected\nSRI:Policy          100 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588   POL-DR-001 CRITICAL \u2190 OVERRIDE\nSRI:Historical        20 / 100   \u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591   no matching incidents\nSRI:Cost              30 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591   $847/mo saving\n\n  COMPOSITE SRI\u2122 = 74.0  \u2192  \u274c DENIED", "originalText": "SRI\u2122 Composite Score\n\nSRI:Infrastructure   32 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591   3 downstream deps affected\nSRI:Policy          100 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588   POL-DR-001 CRITICAL \u2190 OVERRIDE\nSRI:Historical        20 / 100   \u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591   no matching incidents\nSRI:Cost              30 / 100   \u2588\u2588\u2588\u2588\u2588\u2588\u2591\u2591\u2591\u2591\u2591\u2591   $847/mo saving\n\n  COMPOSITE SRI\u2122 = 74.0  \u2192  \u274c DENIED", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300033, "version": 1, "versionNonce": 300034, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4 },

