    { "type": "text", "id": "s5_blocked_text", "x": 1510, "y": 758, "width": 280, "height": 94, "text": "\ud83d\udeab ACTION BLOCKED\n\nAction denied \u2014 vm-23 preserved\nLogged to Cosmos DB audit trail\nGovernance explanation stored\nSlack alert fired", "originalText": "\ud83d\udeab ACTION BLOCKED\n\nAction denied \u2014 vm-23 preserved\nLogged to Cosmos DB audit trail\nGovernance explanation stored\nSlack alert fired", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 500029, "version": 1, "versionNonce": 500030, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s5_blocked_rect", "lineHeight": 1.25 },

