    { "type": "text", "id": "s3_engine_text", "x": 395, "y": 776, "width": 775, "height": 44, "text": "Governance Decision Engine  \u2014  SRI \u2264 25 \u2192 \u2705 APPROVED  |  SRI 26\u201360 \u2192 \u26a0\ufe0f ESCALATED  |  SRI > 60 or CRITICAL \u2192 \u274c DENIED", "originalText": "Governance Decision Engine  \u2014  SRI \u2264 25 \u2192 \u2705 APPROVED  |  SRI 26\u201360 \u2192 \u26a0\ufe0f ESCALATED  |  SRI > 60 or CRITICAL \u2192 \u274c DENIED", "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300037, "version": 1, "versionNonce": 300038, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s3_engine_rect", "lineHeight": 1.25 },

