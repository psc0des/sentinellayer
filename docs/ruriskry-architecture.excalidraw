    { "type": "text", "id": "title_main", "x": 380, "y": 22, "width": 1440, "height": 38, "text": "RuriSkry \u2014 AI Action Governance Engine", "originalText": "RuriSkry \u2014 AI Action Governance Engine", "fontSize": 30, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100001, "version": 1, "versionNonce": 100002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "title_sub", "x": 380, "y": 64, "width": 1440, "height": 22, "text": "Every AI agent action intercepted, scored with SRI\u2122, and governed before it reaches your infrastructure", "originalText": "Every AI agent action intercepted, scored with SRI\u2122, and governed before it reaches your infrastructure", "fontSize": 14, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100003, "version": 1, "versionNonce": 100004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
