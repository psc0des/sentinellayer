    { "type": "text", "id": "s5_slack_text", "x": 1855, "y": 730, "width": 275, "height": 179, "text": "\ud83d\udd14 RuriSkry Alerts\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\u274c DENIED \u2014 vm-23\nAgent: Cost Agent\nSRI Score: 74.0\nViolation: POL-DR-001\n\"DR VM deletion prohibited\"\n\ud83d\udcca View in Dashboard", "originalText": "\ud83d\udd14 RuriSkry Alerts\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\u274c DENIED \u2014 vm-23\nAgent: Cost Agent\nSRI Score: 74.0\nViolation: POL-DR-001\n\"DR VM deletion prohibited\"\n\ud83d\udcca View in Dashboard", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#fca5a5", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 500035, "version": 1, "versionNonce": 500036, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4 },

