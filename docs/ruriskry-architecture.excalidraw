    { "type": "text", "id": "s5_exec_text", "x": 1510, "y": 225, "width": 280, "height": 134, "text": "Execution Gateway\n\nLLM reads resource state \u2192\nPlans fix step-by-step \u2192\nHuman reviews plan \u2192\nLLM executes + verifies\n\u21a9 One-click rollback", "originalText": "Execution Gateway\n\nLLM reads resource state \u2192\nPlans fix step-by-step \u2192\nHuman reviews plan \u2192\nLLM executes + verifies\n\u21a9 One-click rollback", "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 500017, "version": 1, "versionNonce": 500018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "s5_exec_rect", "lineHeight": 1.25 },

