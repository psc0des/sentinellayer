# =============================================================================
# RuriSkry — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed to version control.
#
# Every variable here corresponds 1:1 to a field in src/config.py.
# src/config.py is the single source of truth for defaults and documentation.
# =============================================================================

# =============================================================================
# Microsoft Foundry (Azure OpenAI)
# Populated automatically by scripts/setup_env.sh from Terraform outputs.
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-foundry.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_KEY_SECRET_NAME=foundry-primary-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# =============================================================================
# Azure AI Search
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_API_KEY_SECRET_NAME=search-primary-key
AZURE_SEARCH_INDEX=incident-history

# =============================================================================
# Azure Cosmos DB (SQL API)
# Cosmos containers are created by Terraform — do not rename unless you also
# update infrastructure/terraform-core/main.tf.
# =============================================================================
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=
COSMOS_KEY_SECRET_NAME=cosmos-primary-key
COSMOS_DATABASE=ruriskry
COSMOS_CONTAINER_DECISIONS=governance-decisions
COSMOS_CONTAINER_SCAN_RUNS=governance-scan-runs
COSMOS_CONTAINER_ALERTS=governance-alerts
COSMOS_CONTAINER_EXECUTIONS=governance-executions
COSMOS_CONTAINER_INVENTORY=resource-inventory
COSMOS_CONTAINER_AGENTS=governance-agents

# =============================================================================
# Azure Cosmos DB (Gremlin API — Dependency Graph)
# =============================================================================
COSMOS_GREMLIN_ENDPOINT=wss://your-cosmos.gremlin.cosmos.azure.com:443/
COSMOS_GREMLIN_DATABASE=dependency-graph
COSMOS_GREMLIN_CONTAINER=resources

# =============================================================================
# Azure Resource Graph
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
# Optional: human-friendly label shown in the dashboard header (no functional effect)
AZURE_SUBSCRIPTION_ID_DISPLAY=

# =============================================================================
# Azure Monitor / Log Analytics
# =============================================================================
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# =============================================================================
# Azure Key Vault
# =============================================================================
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# =============================================================================
# Inventory
# =============================================================================
# Warn in UI if inventory is older than this many hours
INVENTORY_STALE_HOURS=24

# =============================================================================
# Slack Notifications
# Get webhook URL: api.slack.com/apps → Incoming Webhooks → Add New Webhook
# See docs/slack-setup.md for the full 5-step guide.
# =============================================================================
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATIONS_ENABLED=true
SLACK_TIMEOUT=10
# URL of the deployed dashboard — used in Slack notification links
DASHBOARD_URL=http://localhost:5173

# =============================================================================
# SRI™ Thresholds and Weights
# =============================================================================
SRI_AUTO_APPROVE_THRESHOLD=25
SRI_HUMAN_REVIEW_THRESHOLD=60
SRI_WEIGHT_INFRASTRUCTURE=0.30
SRI_WEIGHT_POLICY=0.25
SRI_WEIGHT_HISTORICAL=0.25
SRI_WEIGHT_COST=0.20

# =============================================================================
# Dashboard API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
SERVICE_NAME=ruriskry-backend

# =============================================================================
# Scan Scope
# =============================================================================
DEFAULT_RESOURCE_GROUP=

# =============================================================================
# Mode Flags
# =============================================================================
# false = use real Azure SDKs; true = use local JSON fixtures (offline/CI)
USE_LOCAL_MOCKS=false
# true = query Azure Resource Graph for live topology (requires USE_LOCAL_MOCKS=false)
USE_LIVE_TOPOLOGY=true
# true = ops agents return hardcoded proposals (no Azure/LLM needed)
DEMO_MODE=false

# =============================================================================
# LLM Tuning
# =============================================================================
LLM_TIMEOUT=600
LLM_CONCURRENCY_LIMIT=6
SEQUENTIAL_LLM=false

# =============================================================================
# Execution Gateway — Terraform PR Generation
# =============================================================================
# Master switch. false = verdicts are informational only; no PRs are created.
# Set to true only after GITHUB_TOKEN and IAC_GITHUB_REPO are configured.
EXECUTION_GATEWAY_ENABLED=false

# GitHub Personal Access Token with "Contents" + "Pull requests" Read & Write
# on IAC_GITHUB_REPO. Create at:
#   GitHub → Settings → Developer settings → Fine-grained personal access tokens
#
# SECURITY NOTE: In production, store this in Azure Key Vault and reference it
# via Terraform (use_github_pat=true in terraform.tfvars) rather than putting
# the raw value here. The .env file is for local development only.
GITHUB_TOKEN=

# GitHub repo that owns the IaC (format: "owner/repo")
IAC_GITHUB_REPO=

# Path within IAC_GITHUB_REPO to the Terraform config directory.
# Must match the actual directory in the repo (check before deploying).
IAC_TERRAFORM_PATH=infrastructure/terraform-demo

# Prefix for governance-approved PR branches: <prefix>/<resource>-<action_id[:8]>
PR_BRANCH_PREFIX=ruriskry/approved

# =============================================================================
# Org Context (Risk Triage)
# =============================================================================
ORG_NAME=Contoso
ORG_RESOURCE_COUNT=0
# Comma-separated: e.g. "HIPAA,PCI-DSS,SOC2"
ORG_COMPLIANCE_FRAMEWORKS=
# "conservative" | "moderate" | "aggressive"
ORG_RISK_TOLERANCE=moderate
# Comma-separated resource group names: e.g. "rg-prod-payments,rg-prod-identity"
ORG_BUSINESS_CRITICAL_RGS=

# =============================================================================
# Security — API Authentication
# =============================================================================
# When set, all mutating API endpoints require header: X-API-Key: <value>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable (only acceptable behind a private network).
API_KEY=

# When set, POST /api/alert-trigger requires header: Authorization: Bearer <secret>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable (only acceptable behind a private network).
ALERT_WEBHOOK_SECRET=
