# ============================================
# RuriSkry — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# --- Mock vs Azure mode ---
USE_LOCAL_MOCKS=false

# --- Live topology queries (Phase 19) ---
# true = governance agents query Azure Resource Graph for real dependency
# topology and SKU cost instead of data/seed_resources.json.
# Only effective when USE_LOCAL_MOCKS=false AND AZURE_SUBSCRIPTION_ID is set.
USE_LIVE_TOPOLOGY=true

# --- Microsoft Foundry (Terraform-managed) ---
# Key Vault + Managed Identity is recommended for real environments.
# Populate endpoint + secret name from Terraform outputs.
AZURE_OPENAI_ENDPOINT=https://your-foundry.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_KEY_SECRET_NAME=foundry-primary-key
AZURE_OPENAI_DEPLOYMENT=gpt-41
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_API_KEY_SECRET_NAME=search-primary-key
AZURE_SEARCH_INDEX=incident-history

# --- Azure Cosmos DB (SQL API — Decision Audit Trail) ---
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=
COSMOS_KEY_SECRET_NAME=cosmos-primary-key
COSMOS_DATABASE=ruriskry
COSMOS_CONTAINER_DECISIONS=governance-decisions

# --- Azure Cosmos DB (Gremlin API — Dependency Graph) ---
COSMOS_GREMLIN_ENDPOINT=wss://your-cosmos.gremlin.cosmos.azure.com:443/
COSMOS_GREMLIN_DATABASE=dependency-graph
COSMOS_GREMLIN_CONTAINER=resources

# --- Azure Resource Graph ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id

# --- Azure Monitor / Log Analytics ---
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# --- Azure Key Vault ---
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# --- RuriSkry Configuration ---
SRI_AUTO_APPROVE_THRESHOLD=25
SRI_HUMAN_REVIEW_THRESHOLD=60
SRI_WEIGHT_INFRASTRUCTURE=0.30
SRI_WEIGHT_POLICY=0.25
SRI_WEIGHT_HISTORICAL=0.25
SRI_WEIGHT_COST=0.20

# --- Slack Notifications ---
# Get webhook URL from: api.slack.com/apps → Incoming Webhooks → Add New Webhook
# See docs/slack-setup.md for full setup guide.
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATIONS_ENABLED=true
DASHBOARD_URL=http://localhost:5173

# --- Dashboard API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Execution Gateway (Phase 21) ---
# IaC-safe execution: APPROVED verdicts → Terraform PR instead of direct SDK changes.
# Leave EXECUTION_GATEWAY_ENABLED=false (default) to keep verdicts informational only.
# Set to true once GITHUB_TOKEN and IAC_GITHUB_REPO are configured.
EXECUTION_GATEWAY_ENABLED=false

# GitHub Personal Access Token with Contents + Pull requests (Read & Write)
# on the repo specified in IAC_GITHUB_REPO.
# Create at: GitHub → Settings → Developer settings → Fine-grained tokens
GITHUB_TOKEN=

# GitHub repo that owns the IaC (format: "owner/repo", e.g. "psc0des/ruriskry")
IAC_GITHUB_REPO=

# Path within IAC_GITHUB_REPO to the Terraform config directory
IAC_TERRAFORM_PATH=infrastructure/terraform-prod

# --- LLM Tuning ---
LLM_TIMEOUT=600
LLM_CONCURRENCY_LIMIT=6
SEQUENTIAL_LLM=false

# --- Scan Scope ---
DEFAULT_RESOURCE_GROUP=

# --- Demo Mode ---
# true = ops agents return hardcoded proposals (no Azure/LLM needed)
DEMO_MODE=false

# --- Cosmos DB Containers ---
COSMOS_CONTAINER_SCAN_RUNS=governance-scan-runs
COSMOS_CONTAINER_ALERTS=governance-alerts

# --- Org Context (Risk Triage) ---
ORG_NAME=Contoso
ORG_RESOURCE_COUNT=0
ORG_COMPLIANCE_FRAMEWORKS=
ORG_RISK_TOLERANCE=moderate
ORG_BUSINESS_CRITICAL_RGS=
