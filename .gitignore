infrastructure/terraform-core/*.tfstate.*
infrastructure/terraform-core/*.tfstate.backup
infrastructure/terraform-core/terraform.tfvars
infrastructure/terraform-core/tfplan
# .terraform.lock.hcl is intentionally NOT ignored — commit it to pin provider versions

# Terraform — mini prod environment
