# =============================================================================
# terraform.tfvars.example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is in .gitignore and must not be committed.
# =============================================================================

# =============================================================================
# Azure subscriptions
# =============================================================================
# subscription_id        — where RuriSkry infrastructure is deployed (Container App, Cosmos, etc.)
# target_subscription_id — the subscription whose resources RuriSkry will SCAN
#
# SAME subscription (most common — leave target_subscription_id commented out):
#   RuriSkry and the scanned resources live together. No extra steps needed.
#
# DIFFERENT subscriptions (hub-spoke / enterprise):
#   1. Uncomment target_subscription_id and set it to the workload subscription.
#   2. Make sure the identity running `terraform apply` has Owner or
#      User Access Administrator on target_subscription_id (needed to create
#      the cross-subscription role assignments).
#
# Terraform automatically grants RuriSkry's Managed Identity the following
# roles on target_subscription_id — no manual az commands required:
#   - Reader                 (scan / query all resources)
#   - Network Contributor    (modify NSG rules for remediation)
#   - Virtual Machine Contributor  (start / restart VMs for remediation)
# =============================================================================

subscription_id        = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"   # az account show --query id -o tsv
# target_subscription_id = "yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy"  # uncomment for cross-subscription scanning

# Core resources
resource_group_name = "ruriskry-core-engine-rg"
location            = "eastus2"
env                 = "core"
suffix              = "replace-me"   # e.g. "jd4821" — short, globally unique, no spaces
enable_rg_lock      = false          # set true in production to protect against accidental deletion

# Search and Cosmos
search_sku      = "free"
search_location = "eastus"    # separate from main location — eastus2 free tier is frequently exhausted
                               # alternatives: westus2, westeurope, canadacentral
cosmos_free_tier = true
cosmos_location  = "eastus2"

# Foundry (only LLM platform)
foundry_location              = "eastus2"
foundry_account_name          = ""
foundry_custom_subdomain_name = ""

# Foundry project and deployment
create_foundry_project    = true
foundry_project_name      = "ruriskry"
create_foundry_deployment = true
foundry_model             = "gpt-4.1-mini"
foundry_model_version     = "2025-04-14"
foundry_deployment_name   = "gpt-4.1-mini"
foundry_scale_type        = "GlobalStandard"   # GlobalStandard uses shared global pool — no per-subscription quota request needed
foundry_capacity          = 150                # 150K TPM — safe for 3 concurrent agent scans

# ── Upgrading to gpt-5-mini GlobalStandard (better for high-concurrency) ─────
# gpt-5-mini GlobalStandard requires a manual quota request on new subscriptions:
#   1. Go to https://ai.azure.com/quota → select your region → find gpt-5-mini GlobalStandard
#   2. Request increase → enter 3 (= 30,000 TPM)
#   3. Once approved, update these values and run: terraform apply
#        foundry_model           = "gpt-5-mini"
#        foundry_model_version   = "2025-08-07"
#        foundry_deployment_name = "gpt-5-mini"
#        foundry_scale_type      = "GlobalStandard"
#        foundry_capacity        = 30
# ─────────────────────────────────────────────────────────────────────────────

# Key Vault secret names (runtime reads these via .env)
keyvault_secret_name_foundry_key = "foundry-primary-key"
keyvault_secret_name_search_key  = "search-primary-key"
keyvault_secret_name_cosmos_key  = "cosmos-primary-key"

# Optional: object IDs of managed identities that should read Key Vault secrets
managed_identity_principal_ids = []

# =============================================================================
# Container App + Static Web App (deployment)
# =============================================================================

# Docker image to run in the Container App.
# Build and push to ACR first (see docs/SETUP.md → Cloud Deployment).
backend_image        = "ruriskry-backend:latest"
backend_cpu          = 2.0    # 2.0 required for concurrent 3-agent scans; 1.0 causes OOM restarts mid-scan
backend_memory       = "4Gi"  # must match a valid cpu/memory pair for Azure Container Apps
backend_min_replicas = 1
backend_max_replicas = 3

# LLM tuning
# llm_timeout: hard wall-clock cap per agent call. Must be >300s for multi-step loops.
# llm_concurrency_limit: shared semaphore across ALL agents (3 ops + 4 governance + 1 execution
#   = up to 8 callers). 6 is safe at 150K TPM.
llm_timeout           = 600
llm_concurrency_limit = 6

# Execution Gateway — GitHub PAT
# Store the PAT manually in Key Vault (never in this file):
#   az keyvault secret set \
#     --vault-name ruriskry-kv-<suffix> \
#     --name github-pat \
#     --value "github_pat_xxx..."
# Then set use_github_pat = true and re-run terraform apply.
use_github_pat  = false
iac_github_repo = "owner/repo"           # your IaC GitHub repo for Execution Gateway PRs
iac_terraform_path        = "infrastructure/terraform-demo"
execution_gateway_enabled = true

# Org context (risk triage)
org_name                  = "YourOrgName"
org_compliance_frameworks = ""
org_risk_tolerance        = "moderate"

# Slack notifications (optional — leave slack_webhook_url empty to disable)
#
# Full setup guide: docs/slack-setup.md
#
# Short version:
#   1. Go to https://api.slack.com/apps → Create New App → From scratch
#   2. Enable Incoming Webhooks → Add New Webhook to Workspace → pick a channel
#   3. Copy the webhook URL (looks like https://hooks.slack.com/services/T.../B.../XXX...)
#   4. Paste it below and run: terraform apply
#
# The URL is stored in Azure Key Vault and injected into the Container App via
# Managed Identity — it never appears in tfstate or environment variables in plaintext.
slack_webhook_url           = ""
slack_notifications_enabled = true

# Static Web App location (limited regions — leave as eastus2 unless needed)
static_web_app_location = "eastus2"
